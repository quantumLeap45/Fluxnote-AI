# ─── Fluxnote AI Backend — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── OpenRouter (AI Models) ───────────────────────────────────────────────────
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Supabase (Database) ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Model Configuration ───────────────────────────────────────────────────────
# Fast = quick responses, Balanced = quality/speed tradeoff, Deep Think = best quality
# Routed = MoA (Mixture of Agents) — auto-selects up to 3 models per task
MODEL_FAST=google/gemini-3.1-flash-lite-preview
MODEL_BALANCED=openai/gpt-5-nano
MODEL_DEEP_THINK=anthropic/claude-haiku-4.5

# ── File Limits ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
MAX_FILES_PER_SESSION=5

# ── CORS / Frontend ──────────────────────────────────────────────────────────
# Local dev: http://localhost:5173
# Production: your Vercel frontend URL
FRONTEND_URL=http://localhost:5173

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
