# ─── Fluxnote AI Backend — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── OpenRouter (AI Models) ───────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Supabase (Database + File Storage) ──────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Model Configuration (free models for testing) ───────────────────────────
# These map to the Fast / Balanced / Deep Think labels in the UI
MODEL_FAST=mistralai/mistral-7b-instruct:free
MODEL_BALANCED=google/gemma-2-9b-it:free
MODEL_DEEP_THINK=deepseek/deepseek-r1-distill-llama-70b:free

# ── File Limits ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
MAX_FILES_PER_SESSION=5

# ── CORS / Frontend ──────────────────────────────────────────────────────────
# Local dev: http://localhost:5173 (Vite default)
# Production: your Vercel frontend URL
FRONTEND_URL=http://localhost:5173

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
